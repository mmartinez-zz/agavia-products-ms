generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  businessId  String
  title       String
  description String?
  price       Int
  imageUrl    String?
  sourceUrl   String?
  sourceType  String   @default("scraped")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  displayId   Int

  @@index([businessId, displayId])
  @@index([businessId])
  @@map("products")
}

model business_agents {
  id           String     @id
  businessId   String
  enabled      Boolean    @default(true)
  systemPrompt String
  capabilities Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  businesses   businesses @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model business_routing {
  id         String   @id
  businessId String
  type       String
  condition  Json
  agentId    String
  priority   Int
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model businesses {
  id                   String            @id
  name                 String
  phoneNumber          String            @unique
  config               Json
  adminPhone           String?           @db.VarChar(20)
  twilioAccountSid     String?
  twilioAuthToken      String?
  twilioWhatsappNumber String?
  createdAt            DateTime          @default(now())
  business_agents      business_agents[]
  leads                leads[]
  message_logs         message_logs[]
}

model conversation_states {
  id               String                @id
  phone            String
  businessId       String
  state            ConversationStateEnum @default(INIT)
  capturedName     String?
  capturedInterest String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime

  @@unique([phone, businessId])
  @@index([phone, businessId])
}

model leads {
  id                String         @id
  displayId         Int
  name              String
  phone             String
  need              String
  status            LeadStatus     @default(NEW)
  humanRequired     Boolean        @default(false)
  mode              LeadMode       @default(AUTO)
  isHumanActive     Boolean        @default(false)
  activeAgentChatId String?
  businessId        String
  createdAt         DateTime       @default(now())
  businesses        businesses     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  message_logs      message_logs[]

  @@unique([businessId, displayId])
  @@index([businessId])
  @@index([phone, businessId])
  @@index([status])
}

model message_logs {
  id         String           @id
  phone      String
  message    String
  direction  MessageDirection
  businessId String
  leadId     String?
  createdAt  DateTime         @default(now())
  businesses businesses       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leads      leads?           @relation(fields: [leadId], references: [id])

  @@index([businessId, phone])
  @@index([createdAt])
  @@index([leadId])
}

model telegram_sessions {
  id         String               @id
  chatId     String               @unique
  businessId String
  state      TelegramSessionState @default(IDLE)
  tempUrl    String?
  tempMargin Float?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime
}

model tools {
  id        String   @id
  name      String   @unique
  endpoint  String?
  method    String   @default("POST")
  timeout   Int      @default(2000)
  enabled   Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
}

enum ConversationStateEnum {
  INIT
  ASKING_NAME
  LEAD_CAPTURED
}

enum LeadMode {
  AUTO
  HUMAN
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum TelegramSessionState {
  IDLE
  WAITING_URL
  WAITING_MARGIN
}
